# Copiá este archivo como ".env.local" y completá con los datos de tu proyecto de Supabase.
# (Settings → API en el panel de Supabase)

# URL del proyecto (pública)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (pública) — lecturas del sitio y login del admin
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Clave service role (SECRETA — nunca exponer en el navegador)
# Se usa solo del lado del servidor para operaciones del CMS.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
